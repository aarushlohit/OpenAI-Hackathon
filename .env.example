APP_ENV=development
LOG_LEVEL=INFO

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_AUDIO_MODEL=gpt-4o-transcribe
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_TEXT_MODEL=google/gemma-3n-e2b-it
NVIDIA_NIM_VISION_MODEL=google/gemma-3n-e2b-it
NVIDIA_NIM_AUDIO_MODEL=google/gemma-3n-e2b-it

POLLINATIONS_BASE_URL=https://text.pollinations.ai
POLLINATIONS_CHAT_URL=https://gen.pollinations.ai/v1/chat/completions
POLLINATIONS_TEXT_MODEL=openai
POLLINATIONS_VISION_MODEL=openai
POLLINATIONS_EMBEDDING_MODEL=openai

PRIMARY_TEXT_PROVIDER=openai
FALLBACK_TEXT_PROVIDER=nvidia
LAST_RESORT_TEXT_PROVIDER=pollinations
PRIMARY_VISION_PROVIDER=openai
FALLBACK_VISION_PROVIDER=nvidia
LAST_RESORT_VISION_PROVIDER=pollinations
PRIMARY_AUDIO_PROVIDER=openai
FALLBACK_AUDIO_PROVIDER=nvidia
PRIMARY_EMBEDDING_PROVIDER=openai
FALLBACK_EMBEDDING_PROVIDER=pollinations

POSTGRES_DSN=postgresql+asyncpg://hermes:hermes@localhost:5432/hermes_x
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
REDIS_DSN=redis://localhost:6379/0

AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AGENT_TIMEOUT_SECONDS=15
PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
PROVIDER_CIRCUIT_RECOVERY_SECONDS=60
EVENT_STREAM_BUFFER_SIZE=500
RUNTIME_ENABLE_REDIS_CLIENT=false
