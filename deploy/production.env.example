APP_ENV=production
LOG_LEVEL=INFO
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AGENT_TIMEOUT_SECONDS=15
EVENT_STREAM_BUFFER_SIZE=5000
PRIMARY_TEXT_PROVIDER=openai
FALLBACK_TEXT_PROVIDER=nvidia
LAST_RESORT_TEXT_PROVIDER=pollinations
PRIMARY_VISION_PROVIDER=openai
FALLBACK_VISION_PROVIDER=nvidia
LAST_RESORT_VISION_PROVIDER=pollinations
PRIMARY_AUDIO_PROVIDER=openai
FALLBACK_AUDIO_PROVIDER=nvidia
PRIMARY_EMBEDDING_PROVIDER=openai
FALLBACK_EMBEDDING_PROVIDER=pollinations
NVIDIA_NIM_TEXT_MODEL=google/gemma-3n-e2b-it
NVIDIA_NIM_VISION_MODEL=google/gemma-3n-e2b-it
NVIDIA_NIM_AUDIO_MODEL=google/gemma-3n-e2b-it
POLLINATIONS_CHAT_URL=https://gen.pollinations.ai/v1/chat/completions
POSTGRES_DSN=postgresql+asyncpg://hermes:change-me@postgres:5432/hermes_x
REDIS_DSN=redis://redis:6379/0
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
